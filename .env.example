# semantic-kernel-agents — Environment Variables
# Copy to .env and fill in your values.

# Ollama endpoint (default: local, override for remote Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Default model for all agents (override per-agent in config/agents.yaml)
DEFAULT_MODEL=gemma3:12b

# Max revision rounds before forcing finalization
MAX_REVISION_ROUNDS=2

# Optional: Claude API as alternative to Ollama
ANTHROPIC_API_KEY=

# Optional: Azure AI Search for RAG grounding (free F0 tier works)
# Get from Azure Portal → AI Search → Keys and Endpoint
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=research-docs
